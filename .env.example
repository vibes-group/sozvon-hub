# Public IPv4 advertised to WebRTC clients (SFU NAT mapping + TURN relay).
# Required in production; leave unset only for localhost dev.
PUBLIC_IP=127.0.0.1
# Public hostname (used for the WebSocket origin check).
APP_HOSTNAME=sozvon-hub.example.com
# Create a bootstrap invite on first run when there are no users yet; the token
# is printed to the logs so the first user can register.
APP_BOOTSTRAP_INVITE=true
# CSV of CIDRs whose RemoteAddr may set X-Forwarded-For (used to key rate limits
# on the real client IP). Default is loopback-only; set to the reverse proxy /
# docker network range in production.
APP_TRUSTED_PROXIES=10.200.200.0/24
